[
  {
    "id": 1,
    "text": "超无为以至清兮，与泰初而为邻 ——远游",
    "image": "01.jpg"
  },
  {
    "id": 2,
    "text": "他尸骨犹未凉，我此恨怎能偿 ——汉宫秋",
    "image": "02.jpg"
  },
  {
    "id": 3,
    "text": "内心湛然，则无往而不乐 ——人生不过如此",
    "image": "03.jpg"
  },
  {
    "id": 4,
    "text": "美术之为物，欲者不观，观者不欲 ——美学三境",
    "image": "04.jpg"
  },
  {
    "id": 5,
    "text": "自身拥有越丰富，他在别人身上所能发现得到的就越少 ——人类的智慧",
    "image": "05.jpg"
  },
  {
    "id": 6,
    "text": "我见青山多妩媚，料青山见我应如是 ——贺新郎·甚矣吾衰矣",
    "image": "06.jpg"
  },
  {
    "id": 7,
    "text": "相思似海深，旧事如天远 ——卜算子·答施",
    "image": "07.jpg"
  },
  {
    "id": 8,
    "text": "理性的人追求的并非快乐，而只是避免痛苦 ——人生的智慧",
    "image": "08.jpg"
  },
  {
    "id": 9,
    "text": "无垢清净光，慧日破诸暗，能伏灾风火，普明照世间 ——法华经",
    "image": "09.jpg"
  },
  {
    "id": 10,
    "text": "慈母手中线，游子身上衣 ——游子吟 / 迎母漂上作",
    "image": "10.jpg"
  },
  {
    "id": 11,
    "text": "咬定青山不放松，立根原在破岩中 ——竹石",
    "image": "01.jpg"
  },
  {
    "id": 12,
    "text": "花无人戴，酒无人劝，醉也无人管 ——青玉案·年年社日停针线",
    "image": "02.jpg"
  },
  {
    "id": 13,
    "text": "方生方死，方死方生，方可方不可，方不可方可 ——齐物论",
    "image": "03.jpg"
  },
  {
    "id": 14,
    "text": "花有重开日，人无再少年 ——续侄溥赏酴醾劝酒二首其一",
    "image": "04.jpg"
  },
  {
    "id": 15,
    "text": "江南几度梅花发，人在天涯鬓已斑 ——鹧鸪天·雪照山城玉指寒",
    "image": "05.jpg"
  },
  {
    "id": 16,
    "text": "若要断酒法，醒眼看醉人 ——沪谚",
    "image": "06.jpg"
  },
  {
    "id": 17,
    "text": "芝兰生于深林，不以无人而不芳；君子修道立德，不为穷困而改节 ——孔子家语·在厄",
    "image": "07.jpg"
  },
  {
    "id": 18,
    "text": "垂死病中惊坐起，暗风吹雨入寒窗 ——闻乐天授江州司马",
    "image": "08.jpg"
  },
  {
    "id": 19,
    "text": "无情不似多情苦。一寸还成千万缕 ——玉楼春·春恨",
    "image": "09.jpg"
  },
  {
    "id": 20,
    "text": "流水落花春去也，天上人间 ——浪淘沙令·帘外雨潺潺",
    "image": "10.jpg"
  }
]